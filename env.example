# ============================================================
# Environment Configuration
# ============================================================
# Copy this file to create your environment configs:
#   .env            — base defaults (always loaded first)
#   .env.local      — local development overrides
#   .env.production — production / Neon DB overrides
#
# Set APP_ENV to control which overlay is loaded:
#   APP_ENV=local        -> loads .env then .env.local
#   APP_ENV=production   -> loads .env then .env.production
#
# On Render.com, env vars are injected directly (no files needed).
# ============================================================

APP_ENV=local

# Auto-reload API + workers when app/ Python files change (local dev).
# Default: on for APP_ENV=local, off for production. Set RELOAD=0 to disable.
# RELOAD=1

APP_NAME=Job Description Scraper
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# PostgreSQL (local)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/job_scraper
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4.1
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1
OPENAI_TIMEOUT_SECONDS=240

# Langfuse (OpenAI observability — token usage, cost, latency)
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=true

# Browser (Playwright)
BROWSER_POOL_SIZE=5
BROWSER_TIMEOUT_MS=30000
BROWSER_HEADLESS=true

# HTTP Client
HTTP_TIMEOUT_SECONDS=30.0
HTTP_MAX_RETRIES=3
HTTP_RETRY_DELAY_SECONDS=1.0

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_SECOND=2.0
RATE_LIMIT_BURST=5

# Caching
EXTRACTION_CACHE_TTL_SECONDS=86400

# Deduplication
# Per-user recycle window (dedup_recycle_days) is stored in the users table (default 60)
# and editable in the app under Profiles → Deduplication settings — not an env var.
# DEDUP_WINDOW_HOURS is legacy/unused; kept for backward compatibility only.
DEDUP_WINDOW_HOURS=24

# Proxy (HTTP client)
PROXY_ENABLED=false
PROXY_URL=

# Auth — JWT signing secret (required). User passwords are stored in PostgreSQL.
AUTH_SECRET_KEY=your-secret-key-here

# Production CORS: add your deployed frontend origin (local dev origins are built-in)
# FRONTEND_URL=https://your-frontend.onrender.com

# Google Sheets (service account credentials JSON path)
GOOGLE_SHEETS_CREDENTIALS_PATH=google_credentials.json

# Resume builder
RESUME_OUTPUT_ROOT=./resume_output
LIBREOFFICE_PATH=
RESUME_TEMPLATE_PATH=app/templates/resume_template.docx
COVER_LETTER_TEMPLATE_PATH=app/templates/cover_letter_template.docx
USER_TEMPLATES_ROOT=./user_templates
RESUME_TEMPLATE_MAX_BYTES=5000000

# Scraper module (Adzuna spider + optional proxy list for other spiders)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
SCRAPER_PROXY_LIST_PATH=
